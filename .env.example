# =============================================================================
# UTBYTTE AGENTEN — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================================================

# === LLM Configuration ===
# Option A: Ollama (local, no API key required — recommended for self-hosting)
# Install Ollama: https://ollama.ai — then run: ollama pull qwen3:8b
LLM_API_KEY=ollama
LLM_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:8b

# Option B: Any OpenAI-compatible API (OpenAI, Anthropic via proxy, Azure OpenAI, etc.)
# LLM_API_KEY=your_api_key_here
# LLM_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Option C: Groq (free tier, very fast cloud inference)
# Get your API key at: https://console.groq.com
# LLM_API_KEY=your_groq_api_key
# LLM_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# === Embedding Model (local, no API key needed) ===
# Models ranked by quality vs speed:
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2  (420MB, fast, good)
#   intfloat/multilingual-e5-base                                (1.1GB, slower, better)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# === Whisper (speech-to-text) ===
# Models: tiny (fast) | base | small (balanced) | medium | large-v3 (best quality)
# Norwegian accuracy improves significantly from small → medium → large-v3
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# === Storage Paths (relative to backend/) ===
AUDIO_DIR=storage/audio
TRANSCRIPT_DIR=storage/transcripts
CHROMA_PERSIST_DIR=storage/chromadb

# === RSS Feed ===
RSS_FEED_URL=https://feeds.acast.com/public/shows/utbytte

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3002

# === Pipeline ===
MAX_CONCURRENT_EPISODES=3
CHUNK_SIZE_TOKENS=750
CHUNK_OVERLAP_TOKENS=100
